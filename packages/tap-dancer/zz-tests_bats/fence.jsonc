// Fence policy for tap-dancer's bats suite.
//
// Tests are pure CLI behavior tests: they spawn tap-dancer, sh, mkdir,
// grep, cat, and use BATS_TEST_TMPDIR (under /tmp) for scratch. No
// network, no host-fs reads outside /nix/store.
//
// `acceptSharedBinaryCannotRuntimeDeny: ["chroot"]` is required because
// coreutils ships as a multicall binary — without this, fence's runtime
// chroot deny would collaterally block ~30 aliases (mkdir, cat, head,
// tail, etc.), and bats setup/teardown breaks.
{
  "allowPty": false,
  "network": {
    "allowedDomains": []
  },
  "filesystem": {
    "strictDenyRead": true,
    "allowRead": ["/nix/store"],
    "allowExecute": ["/nix/store"],
    "allowWrite": ["/tmp"]
  },
  "command": {
    "useDefaults": true,
    "acceptSharedBinaryCannotRuntimeDeny": ["chroot"]
  }
}
