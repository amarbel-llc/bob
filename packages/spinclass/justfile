root := justfile_directory() + "/../.."

default: build test

build:
    nix build {{root}}#spinclass

test:
    nix develop {{root}} --command go run packages/tap-dancer/ go-test ./packages/spinclass/...

fmt:
    nix develop {{root}} --command go fmt ./packages/spinclass/...

lint:
    nix develop {{root}} --command go vet ./packages/spinclass/...

clean:
    rm -rf result

dev-repo:
    #!/usr/bin/env bash
    set -euo pipefail
    root="{{root}}"
    build_dir="$(cd "$root" && pwd)/build"
    mkdir -p "$build_dir"
    cd "$root"
    nix develop "$root" --command go build -o "$build_dir/spinclass" ./packages/spinclass/cmd/spinclass
    dir=$(mktemp -d)
    trap 'rm -rf "$dir"' EXIT
    git -C "$dir" init -b main
    git -C "$dir" -c commit.gpgsign=false commit --allow-empty -m "initial commit"
    printf 'PATH_add "%s"\n' "$build_dir" > "$dir/.envrc"
    direnv allow "$dir"
    cd "$dir"
    "$SHELL"
