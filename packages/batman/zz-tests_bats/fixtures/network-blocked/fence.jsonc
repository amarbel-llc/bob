// Bisect step: argv-aware runtime exec + allowPty off.
{
  "allowPty": false,
  "network": {
    "allowedDomains": []
  },
  "filesystem": {
    "strictDenyRead": true,
    "allowRead": ["/nix/store"],
    "allowExecute": ["/nix/store"],
    "allowWrite": ["/tmp"]
  },
  "command": {
    "useDefaults": true,
"acceptSharedBinaryCannotRuntimeDeny": ["chroot"]
  }
}
